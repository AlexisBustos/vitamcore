# =========================================================
# VITAM CORE - Backend - Variables de entorno
# Copia este archivo a .env y completa los valores reales.
# El backend valida estas variables al iniciar (src/config/env.ts).
# =========================================================

# Entorno de ejecución: development | production | test
NODE_ENV=development

# Puerto del servidor HTTP
PORT=4000

# URL de conexión a PostgreSQL
# Formato: postgresql://USUARIO:CONTRASENA@HOST:PUERTO/BASEDEDATOS?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vitamcore?schema=public"

# Secreto para firmar los JWT. DEBE tener al menos 32 caracteres.
# Genera uno seguro, por ejemplo: openssl rand -base64 48
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio-de-al-menos-32-caracteres"

# Vida del token de sesión (formato de jsonwebtoken: 7d, 12h, 30m, etc.)
JWT_EXPIRES_IN=12h

# Origen permitido para CORS (URL del frontend)
CORS_ORIGIN=http://localhost:5173

# URL pública del frontend, usada para construir enlaces en correos.
APP_URL=http://localhost:5173

# --- Datos del usuario CEO inicial (usados por el seed) ---
SEED_CEO_NAME="Alex Bustos"
SEED_CEO_EMAIL=ceo@vitam.tech
SEED_CEO_PASSWORD=VitamCore2026!

# =========================================================
# Agent Layer (Sprint 3) — IA Ejecutiva
# La clave del proveedor IA vive SOLO en el backend, nunca en el frontend.
# =========================================================

# Proveedor: 'heuristic' funciona sin API key (analiza datos reales con plantillas).
# 'anthropic' usa Claude (requiere AGENT_API_KEY).
AGENT_PROVIDER=heuristic

# API key del proveedor IA. Déjala vacía para usar el modo heurístico.
# Para Claude: obtén una key en https://console.anthropic.com
AGENT_API_KEY=

# Modelo a usar cuando AGENT_PROVIDER=anthropic
AGENT_MODEL=claude-opus-4-8

# Activa/desactiva por completo el agente
AGENT_ENABLED=true

# Máximo de ítems de cada tipo que se envían como contexto al modelo
AGENT_MAX_CONTEXT_ITEMS=50

# Si es true, el agente puede crear insights y proponer tareas por sí mismo
# (siguen requiriendo aprobación del usuario para convertirse en tareas reales).
AGENT_ALLOW_WRITE_ACTIONS=false

# =========================================================
# Informes por correo (Etapa 2) — informe ejecutivo semanal
# =========================================================

# API key de Resend (https://resend.com). Vacía => el envío se simula (se loguea).
RESEND_API_KEY=

# Remitente: debe ser de un dominio verificado en Resend (p. ej. vitam.tech).
REPORT_EMAIL_FROM=core@vitam.tech

# Destinatario(s) del informe. Uno o varios correos separados por coma.
REPORT_EMAIL_TO=

# Interruptor del informe semanal automático (el cron respeta este valor).
REPORT_ENABLED=true
