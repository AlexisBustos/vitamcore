# =========================================================
# VITAM CORE - Backend - Variables de PRODUCCIÓN (VPS Vultr)
# Copiar a /home/vitam/apps/vitamcore/backend/.env en el servidor.
# NUNCA se versiona (está en .gitignore). Rellenar los <...>.
# =========================================================

NODE_ENV=production
PORT=3007

# PostgreSQL local del VPS (usuario vitam). Base propia de VitamCore.
DATABASE_URL="postgresql://vitam:VitamDB2026Secure@localhost:5432/vitamcore_db?schema=public"

# Secreto JWT (≥32 chars). Generar con: openssl rand -base64 48
JWT_SECRET="<PEGAR_JWT_SECRET_GENERADO>"
JWT_EXPIRES_IN=7d

# Origen permitido para CORS = dominio público del frontend.
CORS_ORIGIN=https://core.vitam.tech

# --- Agent Layer (IA) ---
# Heurístico = sin costo, sin API key. Cambiar a 'anthropic' + key para activar Claude.
AGENT_PROVIDER=heuristic
AGENT_API_KEY=
AGENT_MODEL=claude-opus-4-8
AGENT_ENABLED=true
AGENT_MAX_CONTEXT_ITEMS=50
AGENT_ALLOW_WRITE_ACTIONS=false

# --- Informes por correo (Etapa 2) ---
# Resend: crear key en https://resend.com y verificar el dominio vitam.tech.
RESEND_API_KEY=<PEGAR_RESEND_API_KEY>
REPORT_EMAIL_FROM=core@vitam.tech
REPORT_EMAIL_TO=a.bustos@vitam.tech
REPORT_ENABLED=true
